# Production environment template — copy to .env.prod and fill in real values.
# .env.prod must NEVER be committed to version control.
VISION_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=
OLLAMA_API_BASE=
USE_OLLAMA_API_BASE=false
OPENAI_IMAGE_MAX_DIMENSION=0
OPENAI_IMAGE_DETAIL=high
RATE_LIMIT_RPM=15
APP_ACCESS_KEY=set-a-strong-random-password-here
FRONTEND_URL=https://your-domain.example.com
NEXT_PUBLIC_API_URL=http://backend:8000
