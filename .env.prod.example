# Production environment template — copy to .env.prod and fill in real
# values. .env.prod is gitignored and must NEVER be committed; it is the
# only place the real OPENAI_API_KEY lives on the server.
#
# Deployed environment uses the real OpenAI API only — no GPU on the Linode
# host, so the local Ollama backend (dev-only) isn't an option here, and
# Gemini isn't configured/tested for this deployment.
VISION_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here

# Not used in production — left blank/false on purpose (see comment above).
GEMINI_API_KEY=
OLLAMA_API_BASE=
USE_OLLAMA_API_BASE=false

OPENAI_IMAGE_MAX_DIMENSION=0
OPENAI_IMAGE_DETAIL=high

# Requests/minute this deployment self-limits to. max_safe_concurrency() in
# litellm_adapter.py derives batch concurrency from this — see the
# proxy_read_timeout comment in deploy/nginx.conf for how it drives that
# timeout's sizing. Raise only alongside your actual OpenAI rate-limit tier.
RATE_LIMIT_RPM=15
OPENAI_TPM_LIMIT=200000

APP_ACCESS_KEY=set-a-strong-random-password-here

# Same-origin deployment: nginx serves both the Angular build and /api/* from
# one domain, so this is mainly a safety net for non-browser/cross-origin
# callers rather than something the app's own frontend relies on.
FRONTEND_URL=https://your-subdomain.example.com

# Must be true here — nginx terminates TLS, so the whole app is served over
# HTTPS and the auth cookie should never be sendable over plain HTTP.
COOKIE_SECURE=true
