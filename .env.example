# Generic .env template — copy to .env and customize.
VISION_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_API_BASE=http://localhost:11434/v1
# Set true only when VISION_MODEL is a local Ollama model reached via its
# openai/ compat shim (e.g. openai/gemma4:e4b-it-qat); false for real OpenAI
# models (e.g. openai/gpt-4o-mini) or non-openai/ prefixes (gemini/, ollama/).
USE_OLLAMA_API_BASE=false
# Gemma 4 thinking mode (Ollama models only) — off by default. Set true to A/B
# test accuracy/latency with thinking enabled.
LLM_THINKING=false
# Downscale images to at most this many pixels (longest side) before sending
# to a real OpenAI model — cuts gpt-4o-mini's per-tile image token cost.
# 0 disables resizing. Ignored on the Ollama/Gemma path.
OPENAI_IMAGE_MAX_DIMENSION=0
# "high"/"auto" tile normally (subject to OPENAI_IMAGE_MAX_DIMENSION above);
# "low" collapses to a flat ~2833-token image, bypassing tiling and the
# downscale entirely. Default "high" — "low" risks illegible small print
# (esp. the government warning) on real photographed labels; opt-in only.
OPENAI_IMAGE_DETAIL=high
RATE_LIMIT_RPM=15
APP_ACCESS_KEY=changeme
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
