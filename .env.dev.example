# Dev environment template — copy to .env.dev and customize.
# .env.dev itself is gitignored (may hold a real OPENAI_API_KEY locally);
# this .example file is the one committed to version control.
# Gemini key intentionally blank; dev uses Ollama locally.
VISION_MODEL=gpt-4o-mini
OLLAMA_API_BASE=http://ollama:11434/v1
# "openai/" prefix is ambiguous between real OpenAI models and Ollama-served
# models via its OpenAI-compatible shim. Set true only when VISION_MODEL is a
# local Ollama model (e.g. openai/gemma4:e4b-it-qat); false routes to the real
# OpenAI API (e.g. openai/gpt-4o-mini).
USE_OLLAMA_API_BASE=false
GEMINI_API_KEY=
OPENAI_API_KEY=
# Gemma 4 thinking mode — off by default (latency cost with no accuracy benefit
# for this schema-guided extraction task). Set true to A/B test against the
# golden samples.
LLM_THINKING=false
RATE_LIMIT_RPM=15
OPENAI_IMAGE_MAX_DIMENSION=900
# "high"/"auto" tile normally (subject to OPENAI_IMAGE_MAX_DIMENSION above);
# "low" collapses to a flat ~2833-token image, bypassing tiling and the
# downscale entirely. Default "high" — "low" risks illegible small print
# (esp. the government warning) on real photographed labels; opt-in only.
OPENAI_IMAGE_DETAIL=low
APP_ACCESS_KEY=dev-access-key-change-me
FRONTEND_URL=http://localhost:4200
